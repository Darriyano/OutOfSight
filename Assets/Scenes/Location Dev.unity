--- !u!114 &720000000000001035
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 720000000000001030}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1f2bc9c17a0f4ecbbdd2585e80401478, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  controller: {fileID: 1838207245}
  playbackSource: {fileID: 0}
  visualRoot: {fileID: 720000000000001030}
  prompt: "\u0412\u0437\u044F\u0442\u044C \u043F\u0443\u043B\u044C\u0442"
  disableObjectOnPickup: 1
  unavailableDialogueLines:
  - subtitleText: "\u041C\u043D\u0435 \u043D\u0435 \u0445\u043E\u0447\u0435\u0442\u0441\u044F
      \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u0442\u0435\u043B\u0435\u0432\u0438\u0437\u043E\u0440.
      \u041D\u0430\u0434\u043E \u0443\u0437\u043D\u0430\u0442\u044C, \u0447\u0442\u043E
      \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442 \u043D\u0430 \u043A\u0443\u0445\u043D\u0435."
    voiceClip: {fileID: 0}
    volumeMultiplier: 1
    minimumDuration: 6
    delayAfter: 0
  pickupDialogueLines:
  - subtitleText: "\u0415\u0441\u0442\u044C. \u0422\u0435\u043F\u0435\u0440\u044C
      \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u043F\u0440\u043E\u0431\u043E\u0432\u0430\u0442\u044C
      \u0432\u043A\u043B\u044E\u0447\u0438\u0442\u044C \u0442\u0435\u043B\u0435\u0432\u0438\u0437\u043E\u0440."
    voiceClip: {fileID: 0}
    volumeMultiplier: 1
    minimumDuration: 3
    delayAfter: 4
  - subtitleText: "...\u0425\u043E\u0442\u044F, \u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435,
      \u0441\u0442\u043E\u0438\u0442 \u0441\u043F\u0440\u044F\u0442\u0430\u0442\u044C\u0441\u044F
      \u043F\u0440\u0435\u0436\u0434\u0435, \u0447\u0435\u043C \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u0435\u0433\u043E."
    voiceClip: {fileID: 0}
    volumeMultiplier: 1
    minimumDuration: 4
    delayAfter: 0
